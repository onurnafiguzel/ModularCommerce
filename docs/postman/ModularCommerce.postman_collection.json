{
  "info": {
    "name": "ModularCommerce — Hafta 2 (Catalog)",
    "description": "Hafta 2 kanıt senaryoları: ürün listeleme/filtreleme/detay + Problem Details hata biçimi.\n\nÖn koşul: `docker compose up -d postgres` ve `dotnet run --project src/Bootstrapper/ModularCommerce.Host` çalışıyor olmalı.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:49822",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Modül listesi",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/",
          "host": ["{{baseUrl}}"],
          "path": [""]
        },
        "description": "Host'un canlı modül listesi."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 döner', () => pm.response.to.have.status(200));",
              "pm.test('Catalog modülü listede', () => pm.expect(pm.response.json().modules).to.include('Catalog'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Ürün listesi (sayfalama)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/catalog/products?page=1&pageSize=5",
          "host": ["{{baseUrl}}"],
          "path": ["api", "catalog", "products"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "pageSize", "value": "5" }
          ]
        },
        "description": "FR-2.1: sayfalı ürün listesi. Seed sonrası totalCount=15 beklenir."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 döner', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('15 ürün seed edilmiş', () => pm.expect(body.totalCount).to.eql(15));",
              "pm.test('Sayfa 5 ürün içerir', () => pm.expect(body.items).to.have.lengthOf(5));",
              "pm.test('Ürün alanları dolu', () => { const p = body.items[0]; pm.expect(p).to.have.keys('id','name','sku','price','currency','stockQuantity'); });",
              "// Detay isteği için ilk ürünün id'sini sakla",
              "pm.collectionVariables.set('productId', body.items[0].id);"
            ]
          }
        }
      ]
    },
    {
      "name": "Ürün listesi (arama + fiyat filtresi)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/catalog/products?search=kahve&minPrice=100&maxPrice=1000",
          "host": ["{{baseUrl}}"],
          "path": ["api", "catalog", "products"],
          "query": [
            { "key": "search", "value": "kahve" },
            { "key": "minPrice", "value": "100" },
            { "key": "maxPrice", "value": "1000" }
          ]
        },
        "description": "FR-2.1: ada göre arama (ILIKE) + fiyat aralığı filtresi. Seed verisinde tek eşleşme: EV-3002 Kahve Öğütücü Manuel."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 döner', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('Tek eşleşme (EV-3002)', () => { pm.expect(body.totalCount).to.eql(1); pm.expect(body.items[0].sku).to.eql('EV-3002'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Ürün detayı",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/catalog/products/{{productId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "catalog", "products", "{{productId}}"]
        },
        "description": "FR-2.1: ürün detayı. `productId` değişkeni liste isteğinin test script'inde otomatik dolar — önce listeyi çalıştır."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('200 döner', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('Detay alanları dolu', () => pm.expect(body).to.include.keys('id','name','sku','price','currency','stockQuantity','isActive','createdAtUtc'));",
              "pm.test('Para birimi TRY', () => pm.expect(body.currency).to.eql('TRY'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Bilinmeyen ürün → 404 Problem Details",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/catalog/products/00000000-0000-0000-0000-000000000001",
          "host": ["{{baseUrl}}"],
          "path": ["api", "catalog", "products", "00000000-0000-0000-0000-000000000001"]
        },
        "description": "Domain hata katalogu (`ProductErrors.NotFound`) → RFC 9457 Problem Details."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('404 döner', () => pm.response.to.have.status(404));",
              "pm.test('problem+json içerik tipi', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/problem+json'));",
              "const body = pm.response.json();",
              "pm.test('Domain hata kodu taşır', () => pm.expect(body.title).to.eql('Catalog.Product.NotFound'));",
              "pm.test('traceId var', () => pm.expect(body.traceId).to.be.a('string'));"
            ]
          }
        }
      ]
    },
    {
      "name": "Geçersiz sayfalama → 400 Problem Details",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/catalog/products?pageSize=0",
          "host": ["{{baseUrl}}"],
          "path": ["api", "catalog", "products"],
          "query": [
            { "key": "pageSize", "value": "0" }
          ]
        },
        "description": "İstek biçimi doğrulaması (FluentValidation) → 400 Problem Details."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('400 döner', () => pm.response.to.have.status(400));",
              "pm.test('problem+json içerik tipi', () => pm.expect(pm.response.headers.get('Content-Type')).to.include('application/problem+json'));",
              "pm.test('Validation hata kodu taşır', () => pm.expect(pm.response.json().title).to.eql('Catalog.Products.InvalidQuery'));"
            ]
          }
        }
      ]
    }
  ]
}
