{
  "Serilog": {
    "Enrich": ["FromLogContext"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "Jwt": {
    "Issuer": "ModularCommerce",
    "Audience": "ModularCommerce",
    "SigningKey_UYARI": "Yalnız dev anahtarı — prod anahtar yönetimi Hafta 12 (Key Vault)",
    "SigningKey": "dev-only-signing-key-modular-commerce-2026!",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5432;Database=modular_commerce;Username=postgres;Password=postgres",
    "Redis": "localhost:6379",
    "RabbitMq": "amqp://guest:guest@localhost:5672"
  },
  "Cart": {
    "TtlDays": 7
  },
  "Inventory": {
    "ReservationStrategy": "OptimisticConcurrency",
    "ReservationStrategy_GecerliDegerler": "Naive | OptimisticConcurrency | RedisLock",
    "RedisLock": {
      "TtlSeconds": 5,
      "WaitBudgetMs": 100
    }
  }
}
